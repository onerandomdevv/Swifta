# ==============================================================================
# 💻 TWIZRR BACKEND CONFIGURATION
# ==============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit the real .env.local file to version control.

# ------------------------------------------------------------------------------
# 🏗️ INFRASTRUCTURE
# ------------------------------------------------------------------------------
NODE_ENV="development" # development | production | test | provision
PORT=4000
DATABASE_URL="[NEON_POOLED_URL]"
DIRECT_URL="[NEON_DIRECT_URL]"
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# 🔐 SECURITY & AUTH
# ------------------------------------------------------------------------------
# Generate secrets with: openssl rand -hex 32
JWT_ACCESS_SECRET="your_jwt_access_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# ------------------------------------------------------------------------------
# 💳 PAYMENTS (PAYSTACK)
# ------------------------------------------------------------------------------
# Keys available at: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY="sk_test_xxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxx"
PAYSTACK_WEBHOOK_SECRET="wh_test_xxxx"

# ------------------------------------------------------------------------------
# ☁️ CLOUDINARY
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ------------------------------------------------------------------------------
# 📧 EMAIL (RESEND)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="no-reply@twizrr.com"
WAITLIST_NOTIFY_EMAIL="alerts@twizrr.com"

# ------------------------------------------------------------------------------
# 📱 MESSAGING (AFRICA'S TALKING)
# ------------------------------------------------------------------------------
AT_USERNAME="sandbox" # or your production username
AT_API_KEY="atsk_xxxx"
AT_SENDER_ID="Twizrr"

# ------------------------------------------------------------------------------
# 🤖 AI & VISION (GOOGLE)
# ------------------------------------------------------------------------------
GOOGLE_CLOUD_API_KEY="your_google_cloud_vision_key"
GEMINI_API_KEY="your_google_ai_studio_key"

# ------------------------------------------------------------------------------
# 🟢 WHATSAPP CLOUD API
# ------------------------------------------------------------------------------
WHATSAPP_BOT_NUMBER="234xxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_ACCESS_TOKEN="your_permanent_access_token"
WHATSAPP_VERIFY_TOKEN="your_webhook_verify_token"
WHATSAPP_APP_SECRET="your_app_secret"

# ------------------------------------------------------------------------------
# 🚀 SYSTEM DEFAULTS
# ------------------------------------------------------------------------------
# Initial Admin Credentials (used during DB seeding)
# IMPORTANT: Generate a strong random password (e.g. openssl rand -base64 32)
# NEVER commit real credentials to version control.
ADMIN_BOOTSTRAP_EMAIL="admin@twizrr.com"
ADMIN_BOOTSTRAP_PASSWORD="<GENERATE_SECURE_PASSWORD>"

FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
