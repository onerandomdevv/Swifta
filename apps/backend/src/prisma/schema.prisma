generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminProfile {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  department     String?
  accessLevel    String         @default("STANDARD") @map("access_level")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @default(PENDING) @map("approval_status")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model InventoryEvent {
  id              String            @id @default(uuid()) @db.Uuid
  productId       String            @map("product_id") @db.Uuid
  merchantId      String            @map("merchant_id") @db.Uuid
  eventType       InventoryEventType @map("event_type")
  quantity        Int
  referenceId     String?           @map("reference_id") @db.Uuid
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  merchantProfile MerchantProfile   @relation(fields: [merchantId], references: [id])
  product         Product           @relation(fields: [productId], references: [id])

  @@index([merchantId])
  @@index([productId])
  @@map("inventory_events")
}

model MerchantProfile {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  businessName       String             @map("business_name")
  businessAddress    String?            @map("business_address")
  cacNumber          String?            @map("cac_number")
  bankCode           String?            @map("bank_code")
  bankAccountNo      String?            @map("bank_account_no")
  bankAccountName    String?            @map("bank_account_name")
  verification       VerificationStatus @default(UNVERIFIED)
  onboardingStep     Int                @default(1) @map("onboarding_step")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  businessType       String?            @map("business_type")
  estYear            String?            @map("est_year")
  category           String?
  taxId              String?            @map("tax_id")
  warehouseLocation  String?            @map("warehouse_location")
  distributionCenter String?            @map("distribution_center")
  warehouseCapacity  String?            @map("warehouse_capacity")
  cacDocumentUrl     String?            @map("cac_document_url")
  responseTimeTotal  BigInt             @default(0) @map("response_time_total")
  quoteCount         Int                @default(0) @map("quote_count")
  cacVerified        Boolean            @default(false) @map("cac_verified")
  addressVerified    Boolean            @default(false) @map("address_verified")
  bankVerified       Boolean            @default(false) @map("bank_verified")
  inventoryEvents    InventoryEvent[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders             Order[]
  products           Product[]
  quotes             Quote[]
  rfqs               Rfq[]
  sharedQuotes       SharedQuote[]
  reorderReminders   ReorderReminder[]
  payoutRequests     PayoutRequest[]
  whatsappLink       WhatsAppLink?

  @@map("merchant_profiles")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  channel   NotificationChannel
  isRead    Boolean             @default(false) @map("is_read")
  metadata  Json?
  url       String?
  createdAt DateTime            @default(now()) @map("created_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model OrderEvent {
  id          String       @id @default(uuid()) @db.Uuid
  orderId     String       @map("order_id") @db.Uuid
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  triggeredBy String       @map("triggered_by") @db.Uuid
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  order       Order        @relation(fields: [orderId], references: [id])
  user        User         @relation(fields: [triggeredBy], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_events")
}

model Order {
  id              String            @id @default(uuid()) @db.Uuid
  quoteId         String            @unique @map("quote_id") @db.Uuid
  buyerId         String            @map("buyer_id") @db.Uuid
  merchantId      String            @map("merchant_id") @db.Uuid
  totalAmountKobo BigInt            @map("total_amount_kobo")
  deliveryFeeKobo BigInt            @map("delivery_fee_kobo")
  currency        String            @default("NGN")
  status          OrderStatus       @default(PENDING_PAYMENT)
  deliveryOtp     String?           @map("delivery_otp")
  disputeStatus   OrderDisputeStatus @default(NONE) @map("dispute_status")
  disputeReason   String?           @map("dispute_reason")
  idempotencyKey  String            @unique @map("idempotency_key")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")
  orderEvents      OrderEvent[]
  user             User              @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  merchantProfile  MerchantProfile   @relation(fields: [merchantId], references: [id])
  quote            Quote             @relation(fields: [quoteId], references: [id])
  payments         Payment[]
  reorderReminder  ReorderReminder?

  @@index([buyerId])
  @@index([merchantId])
  @@index([status])
  @@map("orders")
}

model PaymentEvent {
  id        String   @id @default(uuid()) @db.Uuid
  paymentId String   @map("payment_id") @db.Uuid
  eventType String   @map("event_type")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  payment   Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("payment_events")
}

model Payment {
  id                  String           @id @default(uuid()) @db.Uuid
  orderId             String           @map("order_id") @db.Uuid
  paystackReference   String           @unique @map("paystack_reference")
  paystackTransferRef String?          @map("paystack_transfer_ref")
  amountKobo          BigInt           @map("amount_kobo")
  currency            String           @default("NGN")
  status              PaymentStatus    @default(INITIALIZED)
  direction           PaymentDirection
  idempotencyKey      String           @unique @map("idempotency_key")
  verifiedAt          DateTime?        @map("verified_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at")
  paymentEvents       PaymentEvent[]
  order               Order            @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

model PayoutRequest {
  id              String              @id @default(uuid()) @db.Uuid
  merchantId      String              @map("merchant_id") @db.Uuid
  amountKobo      BigInt              @map("amount_kobo")
  status          PayoutRequestStatus @default(PENDING)
  bankName        String?             @map("bank_name")
  accountNumber   String?             @map("account_number")
  accountName     String?             @map("account_name")
  processedAt     DateTime?           @map("processed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at")
  merchantProfile MerchantProfile     @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@map("payout_requests")
}

model ProductStockCache {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @unique @map("product_id") @db.Uuid
  stock     Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id])

  @@map("product_stock_cache")
}

model Product {
  id                String             @id @default(uuid()) @db.Uuid
  merchantId        String             @map("merchant_id") @db.Uuid
  name              String
  description       String?
  unit              String
  categoryTag       String             @map("category_tag")
  minOrderQuantity  Int                @default(1) @map("min_order_quantity")
  isActive          Boolean            @default(true) @map("is_active")
  warehouseLocation String?            @map("warehouse_location")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  imageUrl          String?            @map("image_url")
  inventoryEvents   InventoryEvent[]
  productStockCache ProductStockCache?
  merchantProfile   MerchantProfile    @relation(fields: [merchantId], references: [id])
  rfqs              Rfq[]

  @@index([categoryTag])
  @@index([merchantId])
  @@map("products")
}

model Quote {
  id               String          @id @default(uuid()) @db.Uuid
  rfqId            String          @map("rfq_id") @db.Uuid
  merchantId       String          @map("merchant_id") @db.Uuid
  unitPriceKobo    BigInt          @map("unit_price_kobo")
  totalPriceKobo   BigInt          @map("total_price_kobo")
  deliveryFeeKobo  BigInt          @default(0) @map("delivery_fee_kobo")
  currency         String          @default("NGN")
  notes            String?
  validUntil       DateTime        @map("valid_until")
  status           QuoteStatus     @default(PENDING)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  order            Order?
  merchantProfile  MerchantProfile @relation(fields: [merchantId], references: [id])
  rfq              Rfq             @relation(fields: [rfqId], references: [id])

  @@index([merchantId])
  @@index([rfqId])
  @@map("quotes")
}

model Rfq {
  id                  String          @id @default(uuid()) @db.Uuid
  buyerId             String          @map("buyer_id") @db.Uuid
  productId           String?         @map("product_id") @db.Uuid
  merchantId          String          @map("merchant_id") @db.Uuid
  quantity            Int
  deliveryAddress     String          @map("delivery_address")
  notes               String?
  status              RFQStatus       @default(OPEN)
  expiresAt           DateTime        @map("expires_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at")
  unlistedItemDetails Json?           @map("unlisted_item_details")
  quotes              Quote[]
  user                User            @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  merchantProfile     MerchantProfile @relation(fields: [merchantId], references: [id])
  product             Product?        @relation(fields: [productId], references: [id])

  @@index([buyerId])
  @@index([merchantId])
  @@index([status])
  @@map("rfqs")
}

model StaffAccessToken {
  id        String   @id @default(uuid()) @db.Uuid
  role      UserRole
  tokenHash String   @map("token_hash")
  label     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [createdBy], references: [id])

  @@map("staff_access_tokens")
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  phone             String             @unique
  passwordHash      String             @map("password_hash")
  role              UserRole
  emailVerified     Boolean            @default(false) @map("email_verified")
  phoneVerified     Boolean            @default(false) @map("phone_verified")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  resetToken        String?            @map("reset_token")
  resetTokenExpiry  DateTime?          @map("reset_token_expiry")
  firstName         String             @map("first_name")
  middleName        String?            @map("middle_name")
  lastName          String             @map("last_name")
  adminProfile      AdminProfile?
  merchantProfile   MerchantProfile?
  notifications     Notification[]
  orderEvents       OrderEvent[]
  orders            Order[]
  rfqs              Rfq[]
  staffAccessTokens StaffAccessToken[]
  reorderReminders  ReorderReminder[]

  @@map("users")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum InventoryEventType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  ORDER_RESERVED
  ORDER_RELEASED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  DISPATCHED
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTE
}

enum PaymentDirection {
  INFLOW
  PAYOUT
}

enum PaymentStatus {
  INITIALIZED
  SUCCESS
  FAILED
  REFUNDED
}

enum PayoutRequestStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  REJECTED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum RFQStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum UserRole {
  BUYER
  MERCHANT
  SUPER_ADMIN
  OPERATOR
  SUPPORT
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SharedQuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  EXPIRED
}

enum ReorderReminderStatus {
  PENDING
  SENT
  DISMISSED
  REORDERED
}

enum OrderDisputeStatus {
  NONE
  PENDING
  RESOLVED
}

model SharedQuote {
  id              String            @id @default(uuid()) @db.Uuid
  merchantId      String            @map("merchant_id") @db.Uuid
  slug            String            @unique
  buyerName       String?           @map("buyer_name")
  buyerPhone      String?           @map("buyer_phone")
  buyerEmail      String?           @map("buyer_email")
  items           Json
  subtotalKobo    BigInt            @map("subtotal_kobo")
  deliveryFeeKobo BigInt            @default(0) @map("delivery_fee_kobo")
  totalKobo       BigInt            @map("total_kobo")
  note            String?
  status          SharedQuoteStatus @default(DRAFT)
  expiresAt       DateTime          @map("expires_at")
  viewedAt        DateTime?         @map("viewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")
  merchantProfile MerchantProfile   @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@map("shared_quotes")
}

model ProductAssociation {
  id               String   @id @default(uuid()) @db.Uuid
  productCategoryA String   @map("product_category_a")
  productCategoryB String   @map("product_category_b")
  strength         Float
  promptText       String   @map("prompt_text")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([productCategoryA, productCategoryB])
  @@map("product_associations")
}

model ReorderReminder {
  id               String                @id @default(uuid()) @db.Uuid
  orderId          String                @map("order_id") @db.Uuid
  buyerId          String                @map("buyer_id") @db.Uuid
  merchantId       String                @map("merchant_id") @db.Uuid
  productCategory  String                @map("product_category")
  productName      String                @map("product_name")
  originalQuantity Int                   @map("original_quantity")
  remindAt         DateTime              @map("remind_at")
  status           ReorderReminderStatus @default(PENDING)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at")
  order            Order                 @relation(fields: [orderId], references: [id])
  user             User                  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  merchantProfile  MerchantProfile       @relation(fields: [merchantId], references: [id])

  @@unique([orderId])
  @@index([status, remindAt])
  @@index([buyerId])
  @@map("reorder_reminders")
}

model WhatsAppLink {
  id          String          @id @default(uuid()) @db.Uuid
  phone       String          @unique
  merchantId  String          @unique @map("merchant_id") @db.Uuid
  linkedAt    DateTime        @default(now()) @map("linked_at")
  isActive    Boolean         @default(true) @map("is_active")
  merchant    MerchantProfile @relation(fields: [merchantId], references: [id])

  @@map("whatsapp_links")
}
