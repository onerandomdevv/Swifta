{
  "name": "twizrr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "defu": ">=6.1.5",
      "tar": ">=7.5.11",
      "micromatch": ">=4.0.8",
      "braces": ">=3.0.3",
      "cross-spawn": ">=7.0.6",
      "nanoid": ">=3.3.8",
      "express": ">=4.19.2",
      "body-parser": ">=1.20.3",
      "ws": ">=8.17.1",
      "cookie": ">=0.7.0",
      "send": ">=0.19.0",
      "serve-static": ">=1.16.0",
      "effect": ">=3.20.0",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "next@<14.2.15": "^14.2.15",
      "hono": ">=4.12.7",
      "webpack": ">=5.104.1",
      "minimatch": ">=3.1.4",
      "multer": ">=2.1.1",
      "serialize-javascript": ">=7.0.5",
      "file-type": ">=21.3.2",
      "brace-expansion": ">=1.1.13",
      "@hono/node-server": ">=1.19.10"
    }
  },
  "lint-staged": {
    "apps/backend/**/*.ts": [
      "eslint --fix",
      "node scripts/security-sentinel.js apps/backend",
      "prettier --write"
    ],
    "apps/web/**/*.ts": [
      "eslint --fix",
      "node scripts/security-sentinel.js apps/web",
      "prettier --write"
    ]
  }
}
